# Color and Appearance
theme = Dracula
background-opacity = 0.8

# Font
font-family = Hack Nerd Font Mono
font-size = 14

# Shell
command = /opt/homebrew/bin/fish

# Keybindings: ON=splits-terminal.ghostty / OFF=splits-tmux.ghostty (empty)
# Toggle with: terminal-splits [on|off|toggle|status]
config-file = ~/.config/ghostty/splits.ghostty
